<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Search &amp; Filter"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etSearchDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search by description..."
        android:inputType="text" />

    <EditText
        android:id="@+id/etMinAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Min Amount"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/etMaxAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Max Amount"
        android:inputType="numberDecimal" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sort By:"
        android:layout_marginTop="8dp"/>

    <Spinner
        android:id="@+id/spinnerSort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/btnDoSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/search"
        android:layout_marginTop="16dp" />

    <ListView
        android:id="@+id/lvSearchResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp" />

</LinearLayout>
